# Disable directory listing
Options -Indexes

# Default charset
AddDefaultCharset UTF-8

# Security headers (wrapped with IfModule to avoid errors if modules missing)
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
</IfModule>

RewriteEngine On
RewriteBase /

# Standard routing: if file/dir exists, serve it
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Optional: If you are using clean URLs (like /inglewood instead of /inglewood.html), uncomment below:
# RewriteCond %{REQUEST_FILENAME}.html -f
# RewriteRule ^(.*)$ $1.html [L]
